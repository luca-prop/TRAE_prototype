# -----------------------------------------------------------------------------
# Prisma Database Connection
# -----------------------------------------------------------------------------
# SQLite (Local Development) or PostgreSQL (Production)
DATABASE_URL=
# Supabase Direct Connection for Prisma migrations (Production)
DIRECT_URL=

# -----------------------------------------------------------------------------
# Security & Auth (Server-side ONLY)
# -----------------------------------------------------------------------------
# Passcode for B2B Partner Portal Access
SECRET_B2B=
# Passcode for Admin Console Access
SECRET_ADMIN=

# -----------------------------------------------------------------------------
# External APIs (Server-side ONLY)
# -----------------------------------------------------------------------------
# MOLIT (국토교통부) API Key for Batch Jobs
MOLIT_API_KEY=
# Slack Webhook URL for Developer Alerts (Optional)
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Public API Keys (Exposed to Client)
# -----------------------------------------------------------------------------
# Amplitude Analytics API Key (Optional)
NEXT_PUBLIC_AMPLITUDE_API_KEY=
